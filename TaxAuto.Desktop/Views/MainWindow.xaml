<Window x:Class="TaxAuto.Desktop.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:TaxAuto.Desktop.Views"
        Title="TaxAuto Desktop"
        Height="450"
        Width="800">

    <Grid>
        <TabControl>
            <TabItem Header="매입">
                <views:DocumentOcrTabView DataContext="{Binding PurchaseTab}" />
            </TabItem>

            <TabItem Header="매출">
                <views:DocumentOcrTabView DataContext="{Binding SalesTab}" />
            </TabItem>

            <TabItem Header="작업지시">
                <views:DocumentOcrTabView DataContext="{Binding WorkOrderTab}" />
            </TabItem>
        </TabControl>
    </Grid>
</Window>